# 신원 등 비공개 설정은 ~/.gitconfig.local에 (repo에 커밋되지 않음)
[include]
	path = ~/.gitconfig.local
[core]
	excludesfile = ~/.gitignore
	autocrlf = input
[init]
	defaultBranch = main
[credential]
	helper = osxkeychain
[credential "https://github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
