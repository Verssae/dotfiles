# ~/.zshrc — https://github.com/Verssae/dotfiles
# 셸 설정은 이 파일 하나로 관리한다.

export DOTFILES=$HOME/.dotfiles

# 비밀 환경변수는 ~/.localrc에 (repo 밖)
[ -f ~/.localrc ] && source ~/.localrc

# ------------------------------------------------------------------
# PATH / env
# ------------------------------------------------------------------

export EDITOR='nvim'

# homebrew
export PATH="/opt/homebrew/bin:$PATH"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# pnpm
export PNPM_HOME="$HOME/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# java (corretto 1.8)
if /usr/libexec/java_home -v 1.8 &>/dev/null; then
  export JAVA_HOME="$(/usr/libexec/java_home -v 1.8)"
fi

export PATH="$PATH:$HOME/jf/target/release"
export PATH="$HOME/.local/bin:$PATH"
export PATH="$HOME/.antigravity/antigravity/bin:$PATH"

# ------------------------------------------------------------------
# aliases
# ------------------------------------------------------------------

# eza instead of ls
alias ls='eza -al'
alias ll='eza -lga --icons'

# always neovim
alias vi='nvim'
alias vim='nvim'

# git
alias gs='git status -sb'
alias gb='git branch'
alias gc='git commit'
alias gca='git commit -a'
alias gco='git checkout'
alias gac='git add -A && git commit -m'
alias gl='git pull --prune'
alias gp='git push origin HEAD'
alias glog="git log --graph --pretty=format:'%Cred%h%Creset %an: %s - %Creset %C(yellow)%d%Creset %Cgreen(%cr)%Creset' --abbrev-commit --date=relative"

# ------------------------------------------------------------------
# functions ($DOTFILES/functions: extract, gf)
# ------------------------------------------------------------------

fpath=($DOTFILES/functions $fpath)
autoload -U $DOTFILES/functions/*(:t)

# ------------------------------------------------------------------
# completion
# ------------------------------------------------------------------

# brew가 제공하는 컴플리션 (brew, ghostty 등)
fpath=(/opt/homebrew/share/zsh/site-functions $fpath)

setopt COMPLETE_IN_WORD

# 소문자 입력으로 대문자 매칭 허용
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'
# 탭 문자 붙여넣기 시 컴플리션 발동 방지
zstyle ':completion:*' insert-tab pending

autoload -U compinit
compinit

# bun completions
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"

# OpenClaw completions
[ -f "$HOME/.openclaw/completions/openclaw.zsh" ] && source "$HOME/.openclaw/completions/openclaw.zsh"

# ------------------------------------------------------------------
# fzf / fzf-tab
# ------------------------------------------------------------------

[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# fzf-tab (must load after compinit)
FZF_TAB="/opt/homebrew/opt/fzf-tab/share/fzf-tab/fzf-tab.zsh"
[ -f "$FZF_TAB" ] && source "$FZF_TAB"
zstyle ':completion:*' menu select
zstyle ':fzf-tab:*' switch-group ',' '.'

# ------------------------------------------------------------------
# history
# ------------------------------------------------------------------

HISTFILE=~/.zsh_history
HISTSIZE=100000
SAVEHIST=100000

setopt APPEND_HISTORY
setopt SHARE_HISTORY
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_REDUCE_BLANKS
setopt INC_APPEND_HISTORY
setopt HIST_VERIFY
setopt EXTENDED_HISTORY

# ------------------------------------------------------------------
# plugins (keep syntax-highlighting near the end)
# ------------------------------------------------------------------

# zsh-autosuggestions
if [ -f /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh ]; then
  source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
fi
bindkey '^[OC' forward-char  # Right Arrow accepts one char; use Ctrl+Space for full accept
# bindkey '^ ' autosuggest-accept

# zsh-history-substring-search: ↑/↓로 현재 입력 문자열 기준 검색
if [ -f /opt/homebrew/share/zsh-history-substring-search/zsh-history-substring-search.zsh ]; then
  source /opt/homebrew/share/zsh-history-substring-search/zsh-history-substring-search.zsh
  bindkey '^[[A' history-substring-search-up
  bindkey '^[[B' history-substring-search-down
fi

# zsh-syntax-highlighting
if [ -f /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]; then
  source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
fi

# ------------------------------------------------------------------
# prompt
# ------------------------------------------------------------------

eval "$(starship init zsh)"
